{
  "name": "riftbound-arena",
  "productName": "Riftbound Arena",
  "version": "0.11.10",
  "description": "Mythic fantasy auto battler prototype",
  "main": "main.js",
  "author": "VonScott Bair",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "node ./node_modules/@electron-forge/cli/dist/electron-forge-start.js",
    "package": "node ./node_modules/@electron-forge/cli/dist/electron-forge-package.js",
    "make": "node ./node_modules/@electron-forge/cli/dist/electron-forge-make.js"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "name": "Riftbound Arena",
        "executableName": "Riftbound Arena",
        "asar": true
      },
      "makers": [
        {
          "name": "@electron-forge/maker-squirrel",
          "config": {
            "name": "riftbound_arena",
            "setupExe": "RiftboundArenaSetup.exe",
            "noMsi": true
          }
        }
      ]
    }
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "electron": "^37.4.0",
    "node": "^22.13.1"
  }
}
